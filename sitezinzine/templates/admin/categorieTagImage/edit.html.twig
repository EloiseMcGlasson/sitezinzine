{% extends 'admin/admin.html.twig' %}

{% block title %}Modifier une image annuelle{% endblock %}

{% block body %}
<div class="bodyTagImageEdit">
    <div class="page-header">
        <h1>Modifier une image annuelle</h1>

        <div class="header-actions">
            <a href="{{ path('admin_categorieTagImage_index') }}" class="btn-back">
                Retour à la liste
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    {{ include('admin/categorieTagImage/_form.html.twig', {
        form: form,
        categorieTagImage: categorieTagImage,
        button_label: 'Enregistrer'
    }) }}
</div>

<style>
    .bodyTagImageEdit {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px 40px;
        font-family: "Montserrat Alternates", sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2rem;
    }

    .header-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-back {
        display: inline-block;
        background: #222;
        color: #fff;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 700;
    }

    .btn-back:hover {
        background: #000;
    }

    .flash {
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .flash-success {
        background: #e8f5e9;
        color: #1b5e20;
    }

    .flash-error {
        background: #ffebee;
        color: #b71c1c;
    }
</style>
{% endblock %}