{% extends 'admin/admin.html.twig' %}

{% block title %}Gestion des règles de programmation{% endblock %}

{% block body %}
<style>
.main-content .programmation-rule-index,
.main-content .programmation-rule-index *{
  box-sizing: border-box;
}

.main-content .programmation-rule-index{
  font-family: "Montserrat Alternates", sans-serif;
  max-width: 1280px;
  margin: 18px auto 28px;
  padding: 16px;
  color: #1C1C1A;
}

.main-content .programmation-rule-index .page-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.main-content .programmation-rule-index h1{
  margin: 0;
  color: #E4013A;
  font-size: 26px;
  font-weight: 900;
}

.main-content .programmation-rule-index .btn-create{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 18px;
  border-radius: 26px;
  background: #E4013A;
  color: #fff;
  text-decoration: none;
  font-weight: 900;
  transition: background-color .2s ease;
}

.main-content .programmation-rule-index .btn-create:hover{
  background: #b30021;
}

.main-content .programmation-rule-index .table-wrap{
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  overflow: hidden;
}

.main-content .programmation-rule-index table{
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.main-content .programmation-rule-index th,
.main-content .programmation-rule-index td{
  padding: 12px 14px;
  text-align: left;
  border-bottom: 1px solid #eee;
  vertical-align: middle;
}

.main-content .programmation-rule-index th{
  background: #fafafa;
  font-size: 14px;
  color: #333;
  font-weight: 900;
}

.main-content .programmation-rule-index td{
  font-size: 14px;
}

.main-content .programmation-rule-index .badge{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
  white-space: nowrap;
}

.main-content .programmation-rule-index .badge-active{
  background: #e7f8ec;
  color: #1d7a37;
}

.main-content .programmation-rule-index .badge-inactive{
  background: #f5f5f5;
  color: #666;
}

.main-content .programmation-rule-index .actions{
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.main-content .programmation-rule-index .btn-edit,
.main-content .programmation-rule-index .btn-slots,
.main-content .programmation-rule-index .btn-delete{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 110px;
  padding: 8px 12px;
  border: 0;
  border-radius: 20px;
  text-decoration: none;
  font-weight: 800;
  font-size: 13px;
  cursor: pointer;
}

.main-content .programmation-rule-index .btn-edit,
.main-content .programmation-rule-index .btn-slots{
  background: #f3f3f3;
  color: #1C1C1A;
}

.main-content .programmation-rule-index .btn-edit:hover,
.main-content .programmation-rule-index .btn-slots:hover{
  background: #e2e2e2;
}

.main-content .programmation-rule-index .btn-delete{
  background: #E4013A;
  color: #fff;
}

.main-content .programmation-rule-index .btn-delete:hover{
  background: #b30021;
}

.main-content .programmation-rule-index .empty{
  padding: 24px 16px;
  text-align: center;
  color: #666;
  font-weight: 700;
}

.main-content .programmation-rule-index .mobile-cards{
  display: none;
}

@media (max-width: 960px){
  .main-content .programmation-rule-index{
    margin: 14px 12px 22px;
    padding: 0;
  }

  .main-content .programmation-rule-index .table-wrap{
    display: none;
  }

  .main-content .programmation-rule-index .mobile-cards{
    display: grid;
    gap: 12px;
  }

  .main-content .programmation-rule-index .card{
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    padding: 14px 12px;
  }

  .main-content .programmation-rule-index .card h2{
    margin: 0 0 10px 0;
    font-size: 18px;
    color: #E4013A;
  }

  .main-content .programmation-rule-index .card p{
    margin: 6px 0;
    font-size: 14px;
  }
}
</style>

<div class="programmation-rule-index">
  <div class="page-header">
    <h1>Règles de programmation</h1>
    <a href="{{ path('admin_programmationRule_create') }}" class="btn-create">Créer une règle</a>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Catégorie</th>
          <th>Valide du</th>
          <th>Valide au</th>
          <th>Actif</th>
          <th>Créneaux</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for rule in rules %}
        <tr>
          <td>{{ rule.category ? rule.category.titre : '—' }}</td>
          <td>{{ rule.validFrom ? rule.validFrom|date('d/m/Y') : '—' }}</td>
          <td>{{ rule.validUntil ? rule.validUntil|date('d/m/Y') : '—' }}</td>
          <td>
            {% if rule.isActive %}
              <span class="badge badge-active">Oui</span>
            {% else %}
              <span class="badge badge-inactive">Non</span>
            {% endif %}
          </td>
          <td>{{ rule.slots|length }}</td>
          <td>
            <div class="actions">
              <a href="{{ path('admin_programmationRule_edit', {id: rule.id}) }}" class="btn-edit">Modifier</a>
              <a href="{{ path('admin_programmationRuleSlot_index', {ruleId: rule.id}) }}" class="btn-slots">Créneaux</a>

              <form method="post"
                    action="{{ path('admin_programmationRule_delete', {id: rule.id}) }}"
                    onsubmit="return confirm('Supprimer cette règle de programmation ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_rule_' ~ rule.id) }}">
                <button type="submit" class="btn-delete">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="6" class="empty">Aucune règle de programmation pour le moment.</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="mobile-cards">
    {% for rule in rules %}
      <div class="card">
        <h2>{{ rule.category ? rule.category.titre : 'Règle sans catégorie' }}</h2>
        <p><strong>Valide du :</strong> {{ rule.validFrom ? rule.validFrom|date('d/m/Y') : '—' }}</p>
        <p><strong>Valide au :</strong> {{ rule.validUntil ? rule.validUntil|date('d/m/Y') : '—' }}</p>
        <p><strong>Créneaux :</strong> {{ rule.slots|length }}</p>
        <p>
          <strong>Actif :</strong>
          {% if rule.isActive %}
            <span class="badge badge-active">Oui</span>
          {% else %}
            <span class="badge badge-inactive">Non</span>
          {% endif %}
        </p>

        <div class="actions">
          <a href="{{ path('admin_programmationRule_edit', {id: rule.id}) }}" class="btn-edit">Modifier</a>
          <a href="{{ path('admin_programmationRuleSlot_index', {ruleId: rule.id}) }}" class="btn-slots">Créneaux</a>

          <form method="post"
                action="{{ path('admin_programmationRule_delete', {id: rule.id}) }}"
                onsubmit="return confirm('Supprimer cette règle de programmation ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_rule_' ~ rule.id) }}">
            <button type="submit" class="btn-delete">Supprimer</button>
          </form>
        </div>
      </div>
    {% else %}
      <div class="card">
        <p class="empty">Aucune règle de programmation pour le moment.</p>
      </div>
    {% endfor %}
  </div>
</div>
{% endblock %}