{% extends 'admin/admin.html.twig' %}

{% block title %}
    Tous les invités !
{% endblock %}

{% block body %}
    <style>
        .admin-invite-page {
            padding: 0 20px;
        }

        .admin-invite-page .create {
            text-align: left;
            margin: 0 0 20px;
        }

        .admin-invite-page .btn-create {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 8px;
            background: #E4013A;
            color: #fff;
            text-decoration: none;
            font-weight: 800;
        }

        .admin-invite-page .btn-create:hover {
            background: #b8002f;
            color: #fff;
            text-decoration: none;
        }

        .admin-invite-page h1 {
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .admin-invite-page {
                padding: 0 12px;
            }

            .admin-invite-page .create {
                text-align: center;
            }

            .admin-invite-page .btn-create {
                display: block;
                width: 100%;
                max-width: 280px;
                margin: 0 auto;
                padding: 10px 12px;
                font-size: 14px;
                border-radius: 10px;
            }
        }
    </style>

    <div class="admin-invite-page">
        <p class="create">
            <a class="btn-create" href="{{ path('admin.InviteOldAnimateur.create') }}">
                Créer un nouveau invité ou ancien·ne animateurice
            </a>
        </p>

        <h1>Liste des invités et anciens·ne animateur·ice·s</h1>

        <div class="admin-card-grid">
            {% for inviteOldAnimateur in InviteOldAnimateurs %}
                {% set badges = [] %}

                {% if inviteOldAnimateur.ancienanimateur %}
                    {% set badges = badges|merge([
                        { label: 'Ancien·ne animateurice', class: 'admin-card__badge--primary' }
                    ]) %}
                {% else %}
                    {% set badges = badges|merge([
                        { label: 'Invité·e', class: 'admin-card__badge--secondary' }
                    ]) %}
                {% endif %}

                {% set content %}
                    {% if inviteOldAnimateur.mail %}
                        <p><strong>Email :</strong> {{ inviteOldAnimateur.mail }}</p>
                    {% endif %}

                    {% if inviteOldAnimateur.phoneNumber %}
                        <p><strong>Téléphone :</strong> {{ inviteOldAnimateur.phoneNumber }}</p>
                    {% endif %}
                {% endset %}

                {% set actions %}
                    <a
                        class="btn-action"
                        href="{{ path('admin.InviteOldAnimateur.edit', { id: inviteOldAnimateur.id }) }}"
                    >
                        Éditer
                    </a>
                {% endset %}

                {% include 'partials/_admin_card.html.twig' with {
                    title: inviteOldAnimateur.lastName ~ ' ' ~ inviteOldAnimateur.firstName,
                    titleUrl: path('admin.InviteOldAnimateur.show', { id: inviteOldAnimateur.id }),
                    badges: badges,
                    content: content|trim,
                    actions: actions
                } only %}
            {% endfor %}
        </div>
    </div>
{% endblock %}