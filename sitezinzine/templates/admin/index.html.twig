{% extends 'admin/admin.html.twig' %}
{% block title %}
  Administration - Radio Zinzine
{% endblock %}
{% block body %}
  <style>
/* ===== Admin Dashboard (scope) ===== */
.admin-dashboard {
  color: white;
  font-family: "Montserrat Alternates", sans-serif;
}

/* ===== Bloc header user ===== */
.admin-dashboard .alert.alert-info {
  background: rgba(28, 28, 26, 0.55);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 12px;
  padding: 16px;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

/* Boutons du header */
.admin-dashboard .alert a.btn.btn-danger {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .6rem 1rem;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
}

.admin-dashboard .alert a.btn.btn-danger:hover {
  background: rgba(255,255,255,0.14);
  border-color: rgba(255,255,255,0.28);
}

/* Badges rôles */
.admin-dashboard .badge.bg-primary {
  display: inline-block;
  padding: .25rem .6rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
  font-weight: 700;
  margin-right: 6px;
}

/* Intro */
.admin-dashboard p {
  max-width: 900px;
  margin: 0 auto 10px auto;
  line-height: 1.6;
}

.admin-dashboard p a {
  color: #fff;
  text-decoration: underline;
  text-decoration-thickness: 2px;
  text-underline-offset: 3px;
}

.admin-dashboard p a:hover {
  color: #1C1C1A;
  background: #fff;
  text-decoration: none;
  padding: 0 .2rem;
  border-radius: 4px;
}

/* ===== Layout général ===== */
.admin-dashboard .row.mt-4 {
  display: flex;
  gap: 16px;
  align-items: stretch;
  flex-wrap: wrap;
}

/* Colonne gauche */
.admin-dashboard .dashboard-left-column {
  flex: 1 1 260px;
  min-width: 260px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Colonne droite */
.admin-dashboard .dashboard-right-column {
  flex: 2 1 520px;
  min-width: 320px;
}

/* Cartes */
.admin-dashboard .card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 12px;
  box-shadow: 0 10px 24px rgba(0,0,0,0.18);
}

.admin-dashboard .card .card-body {
  padding: 16px;
  color: white;
}

/* Titres / textes */
.admin-dashboard .card-title {
  color: #fff;
  font-weight: 900;
  margin: 0 0 6px 0;
}

.admin-dashboard .card-text {
  margin: 0 0 12px 0;
  color: rgba(255,255,255,0.92);
}

/* ===== Boutons dashboard ===== */
.admin-dashboard a.btn.btn-primary,
.admin-dashboard button.btn.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: .65rem 1rem;
  border-radius: 10px;
  background: #fff;
  color: #1C1C1A;
  border: 1px solid rgba(0,0,0,0.15);
  text-decoration: none;
  font-weight: 800;
  cursor: pointer;
}

.admin-dashboard a.btn.btn-primary:hover,
.admin-dashboard button.btn.btn-primary:hover {
  background: rgba(255,255,255,0.92);
}

/* Bouton secondaire dans le même style visuel */
.admin-dashboard .btn.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: .65rem 1rem;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.18);
  text-decoration: none;
  font-weight: 800;
  cursor: pointer;
}

.admin-dashboard .btn.btn-secondary:hover {
  background: rgba(255,255,255,0.14);
  border-color: rgba(255,255,255,0.28);
}

/* ===== Bloc changelog ===== */
.admin-dashboard .changelog-wrapper {
  max-width: none;
  margin: 0;
}

.admin-dashboard #changelog {
  max-height: 656px;
  overflow-y: auto;
  padding: 12px;
  background: rgba(28, 28, 26, 0.85);
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 10px;
  color: #fff;
  font-size: 0.95rem;
  line-height: 1.5;
}

.admin-dashboard #changelog h1,
.admin-dashboard #changelog h2,
.admin-dashboard #changelog h3 {
  color: #fff;
  font-size: 1.05rem;
  margin: 12px 0 8px 0;
  font-weight: 900;
}

.admin-dashboard #changelog a {
  color: #fff;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.admin-dashboard #changelog ul {
  padding-left: 18px;
  margin: 0 0 10px 0;
}

.admin-dashboard #changelog strong {
  font-weight: 800;
}

.admin-dashboard #changelog::-webkit-scrollbar {
  width: 8px;
}

.admin-dashboard #changelog::-webkit-scrollbar-thumb {
  background-color: rgba(255,255,255,0.35);
  border-radius: 999px;
}

.admin-dashboard #changelog::-webkit-scrollbar-thumb:hover {
  background-color: rgba(255,255,255,0.5);
}

/* ===== Bloc impersonation ===== */
.admin-dashboard .admin-switch-user {
  margin-top: 16px;
}

.admin-dashboard .switch-user-form {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.admin-dashboard .switch-user-form label {
  color: white;
  font-weight: 600;
}

.admin-dashboard .switch-user-select {
  padding: 10px 14px;
  border-radius: 12px;
  border: 2px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.95);
  font-family: "Montserrat Alternates", sans-serif;
  font-size: 1rem;
  cursor: pointer;
}

.admin-dashboard .switch-user-select:focus {
  outline: none;
  border-color: #E40039;
}

.admin-dashboard .impersonation {
  margin-top: 12px;
  padding: 10px 12px;
  border-radius: 10px;
  background: rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.16);
  color: white;
}

.admin-dashboard .switch-user-exit {
  margin-left: 10px;
  color: #fff;
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* ===== Bloc émissions à finaliser ===== */
.admin-dashboard .pending-emissions-list {
  list-style: none;
  margin: 0 0 14px 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.admin-dashboard .pending-emission-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 10px;
  background: rgba(0, 0, 0, 0.18);
  border: 1px solid rgba(255,255,255,0.14);
}

.admin-dashboard .pending-emission-content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}

.admin-dashboard .pending-emission-content strong {
  color: #fff;
  font-weight: 800;
  line-height: 1.3;
}

.admin-dashboard .pending-emission-meta {
  color: rgba(255,255,255,0.82);
  font-size: 0.92rem;
}

.admin-dashboard .pending-emission-badge {
  display: inline-block;
  width: fit-content;
  padding: .22rem .55rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 700;
}

.admin-dashboard .pending-emission-actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex-shrink: 0;
}

.admin-dashboard .pending-emission-actions form {
  margin: 0;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .admin-dashboard .alert a.btn.btn-danger {
    margin-left: 0;
  }
}

@media (max-width: 700px) {
  .admin-dashboard .pending-emission-item {
    flex-direction: column;
    align-items: stretch;
  }

  .admin-dashboard .pending-emission-actions {
    width: 100%;
  }

  .admin-dashboard .pending-emission-actions .btn,
  .admin-dashboard .pending-emission-actions form,
  .admin-dashboard .pending-emission-actions button {
    width: 100%;
  }
}
</style>
  <div class="admin-dashboard container mt-4">
    {# ===== En-tête utilisateur ===== #}
    <div class="alert alert-info">
      Bonjour
      {{ app.user ? app.user.displayName : 'utilisateur' }}
      !
      <a href="{{ path('app_profile_edit') }}" class="btn btn-danger">
        Mon profil
      </a>
      <a href="{{ path('app_logout') }}" class="btn btn-danger">
        <i class="fas fa-sign-out-alt"></i>
        Déconnexion
      </a>
      <div class="mt-2">
        Vos rôles :
        {% for role in app.user ? app.user.roles : [] %}
          <span class="badge bg-primary">
            {{ role|replace({'ROLE_': ''})|title }}
          </span>
        {% endfor %}
      </div>
    </div>
    {# ===== Intro dashboard ===== #}
    <h1>
      Tableau de bord
    </h1>
    <p>
      Bienvenue dans l'interface d'administration de Radio Zinzine.
      Ce site est une démo et est mis à jour régulièrement, les avancées sont indiquées dans le changelog.
    </p>
    <p>
      Pour toute question, suggestion ou correction, n'hésitez pas à me contacter
      <a href="mailto:drelin04@hotmail.fr">
        par mail
      </a>
      ou sur signal (0684847905).
    </p>
    <p>
      Éloïse
    </p>
    <div class="row mt-4">
      {# ===== Colonne gauche ===== #}
      <div class="dashboard-left-column">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">
              Émissions à finaliser
            </h5>
            {% if pendingEmissionsCount > 0 %}
              <p class="card-text">
                Tu as
                {{ pendingEmissionsCount }}
                émission
                {{ pendingEmissionsCount > 1 ? 's' : '' }}
                à compléter.
              </p>
              <ul class="pending-emissions-list">
                {% for emission in pendingEmissions %}
                  <li class="pending-emission-item">
                    <div class="pending-emission-content">
                      <strong>
                        {{ emission.titre }}
                      </strong>
                      {% if emission.categorie %}
                        <span class="pending-emission-meta">
                          {{ emission.categorie.titre }}
                        </span>
                      {% endif %}
                      {% if is_granted('ROLE_SUPER_ADMIN') and emission.users is not empty %}
                        <span class="pending-emission-meta">
                          User
                          {{ emission.users|length > 1 ? 's' : '' }}
                          :
                          {% for linkedUser in emission.users %}
                            {{ linkedUser.displayName ?? linkedUser.username }}
                            {% if not loop.last %}
                              ,
                            {% endif %}
                          {% endfor %}
                        </span>
                      {% endif %}
                      {% if emission.isAutoGenerated %}
                        <span class="pending-emission-badge">
                          Direct auto
                        </span>
                      {% endif %}
                    </div>
                    <div class="pending-emission-actions">
                      <a href="{{ path('admin.emission.edit', {id: emission.id}) }}" class="btn btn-primary">
                        Finaliser
                      </a>
                      <form method="post" action="{{ path('admin.emission.mark_completed', {id: emission.id}) }}" onsubmit="return confirm('Retirer cette émission de la liste des fiches à finaliser ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('mark_completed_' ~ emission.id) }}">
                          <button type="submit" class="btn btn-secondary">
                            Retirer de la liste
                          </button>
                        </form>
                      </div>
                    </li>
                  {% endfor %}
                </ul>
                <a href="{{ path('admin.emission.index') }}" class="btn btn-primary">
                  Voir toutes les émissions
                </a>
              {% else %}
                <p class="card-text">
                  Aucune émission à finaliser pour le moment.
                </p>
              {% endif %}
            </div>
          </div>
        </div>
        {# ===== Colonne droite : changelog ===== #}
        <div class="dashboard-right-column">
          <div class="card changelog-wrapper">
            <div class="card-body">
              <div id="changelog">
                <p>
                  Chargement du changelog...
                </p>
              </div>
            </div>
          </div>
        </div>
        {# ===== Bloc impersonation ===== #}
        {% if is_granted('ROLE_SUPER_ADMIN') or is_granted('ROLE_PREVIOUS_ADMIN') %}
          <div class="col-12">
            <div class="card admin-switch-user">
              <div class="card-body">
                <h5 class="card-title">
                  Changer de rôle
                </h5>
                <form method="get" class="switch-user-form">
                  <label for="switch-user-select">
                    Se connecter en tant que :
                  </label>
                  <select id="switch-user-select" class="switch-user-select" name="_switch_user" onchange="this.form.submit()">
                    <option value="">
                      — Sélectionner un utilisateur —
                    </option>
                    {% for u in users %}
                      <option value="{{ u.username }}">
                        {{ u.username }}
                      </option>
                    {% endfor %}
                  </select>
                </form>
                {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                  <p class="impersonation">
                    Tu es en impersonation 🎭
                    <a class="switch-user-exit" href="?_switch_user=_exit">
                      Revenir à mon compte
                    </a>
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endblock %}
  {% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/marked@3.0.0/lib/marked.min.js"></script>
    <script>
        fetch('{{ asset('changelog.md') }}')
            .then(response => response.text())
            .then(markdownText => {
                const htmlContent = marked(markdownText);
                document.getElementById('changelog').innerHTML = htmlContent;
            })
            .catch(err => {
                console.error('Erreur lors du chargement du changelog:', err);
                document.getElementById('changelog').innerHTML = '<p>Impossible de charger le changelog.</p>';
            });
    </script>
  {% endblock %}
  