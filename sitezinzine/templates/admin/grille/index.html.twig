{% extends 'admin/admin.html.twig' %}
{% block title %}
  Grille de programmation
{% endblock %}
{% block stylesheets %}
  {{ parent() }}
  <style>
    :root{
      --slot-h: 8px;
      --head-h: 44px;
      --grid-bg:#fff;
      --grid-line:#e6e6e6;
      --head-bg:#f0f0f0;
      --head-text:#1c1c1a;
      --hour-text:#3a3a3a;

      --postit:#d75a6f;
      --postit-border:#b9475a;
      --postit-text:#fff;

      --postit-assigned:#8a3f9b;
      --postit-assigned-border:#6d2f7c;

      --postit-rebroadcast:#d9d9d9;
      --postit-rebroadcast-border:#b8b8b8;
      --postit-rebroadcast-text:#3d3d3d;
    }

    .schedule-layout{
      display:flex;
      gap:24px;
      align-items:flex-start;
    }

    .grid-area{
      flex:1;
      min-width:0;
    }

    .sidebar{
      width:320px;
      flex:0 0 320px;
    }

    .schedule-grid{
      display:grid;
      grid-template-columns: 80px repeat(7, 1fr);
      grid-template-rows: var(--head-h) repeat(96, var(--slot-h));
      border-left:1px solid var(--grid-line);
      border-right:1px solid var(--grid-line);
      background:var(--grid-bg);
    }

    .head{
      display:flex;
      align-items:center;
      justify-content:center;
      background:var(--head-bg);
      color:var(--head-text);
      border-bottom:1px solid var(--grid-line);
      border-right:1px solid var(--grid-line);
      font-weight:700;
      font-size:14px;
      padding:0 8px;
      text-align:center;
    }

    .head.hour{
      justify-content:flex-start;
      padding-left:8px;
    }

    .hours-col{
      grid-column:1;
      grid-row:2 / span 96;
      position:relative;
      border-right:1px solid var(--grid-line);
    }

    .h-slot{
      position:absolute;
      left:0;
      right:0;
      height:var(--slot-h);
      border-top:1px solid rgba(0,0,0,.06);
      pointer-events:none;
    }

    .h-slot.hour-start{
      border-top-color:#d8d8d8;
    }

    .hour-label{
      position:absolute;
      left:8px;
      top:0;
      font-size:13px;
      font-weight:700;
      line-height:1;
      color:var(--hour-text);
      transform:none;
    }

    .day-col{
      position:relative;
      grid-row:2 / span 96;
      border-left:1px solid var(--grid-line);
    }

    .day-slot{
      position:absolute;
      left:0;
      right:0;
      height:var(--slot-h);
      border-top:1px solid rgba(0,0,0,.06);
      pointer-events:none;
    }

    .day-slot.hour-start{
      border-top-color:#d8d8d8;
    }

    .day-col.drag-over{
      outline:2px dashed var(--postit);
      outline-offset:-2px;
    }

    .postit{
      position:absolute;
      left:1px;
      right:1px;
      top:0;
      background:var(--postit);
      color:var(--postit-text);
      border:1px solid var(--postit-border);
      border-radius:0;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0 2px;
      font-size:9px;
      font-weight:500;
      line-height:1;
      text-align:center;
      overflow:hidden;
      text-overflow:ellipsis;
      cursor:grab;
      user-select:none;
      z-index:2;
      transition:opacity .2s ease, filter .2s ease;
    }

    .postit.assigned{
      background:var(--postit-assigned);
      border-color:var(--postit-assigned-border);
    }

    .postit.postit--rebroadcast{
      background:var(--postit-rebroadcast);
      color:var(--postit-rebroadcast-text);
      border-color:var(--postit-rebroadcast-border);
      cursor:not-allowed;
      opacity:.82;
      filter:grayscale(.2);
      user-select:none;
    }

    .postit.postit--rebroadcast.assigned{
      background:#d7cfe0;
      border-color:#b7a8c8;
      color:#43384b;
    }

    .postit[data-slots="1"]{
      white-space:nowrap;
    }

    .postit:not([data-slots="1"]){
      white-space:normal;
      line-height:1.05;
      padding:1px 3px;
      word-break:break-word;
    }

    .postit.is-selected{
      outline:2px solid #1c1c1a;
      outline-offset:-2px;
      z-index:5;
    }

    .postit__content{
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:2px;
      width:100%;
    }

    .postit__label{
      display:block;
    }

    .postit__badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:1px 6px;
      border-radius:999px;
      font-size:8px;
      font-weight:700;
      line-height:1;
      background:rgba(255,255,255,.72);
      color:#333;
      max-width:100%;
    }

    .sidebar h2{
      font-size:16px;
      margin:0 0 8px;
      color:var(--head-text);
    }

    .sidebar-mode-switch{
      display:flex;
      gap:8px;
      margin-bottom:12px;
    }

    .mode-btn{
      flex:1 1 0;
      border:1px solid #ddd;
      background:#fff;
      color:#1c1c1a;
      border-radius:999px;
      padding:10px 12px;
      font-size:13px;
      font-weight:800;
      cursor:pointer;
      transition:all .2s ease;
    }

    .mode-btn:hover{
      background:#f7f7f7;
    }

    .mode-btn.is-active{
      background:#E4013A;
      border-color:#E4013A;
      color:#fff;
    }

    #emissions-pool{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    #emissions-pool.drop-pool-hover{
      background:#fff8f8;
      border:2px dashed var(--postit);
      padding:10px;
      border-radius:6px;
    }

    .sidebar-section{
      background:#fff;
      border:1px solid #e6e6e6;
      border-radius:8px;
      padding:12px;
      margin-bottom:16px;
    }

    .sidebar-section h3{
      margin:0 0 10px;
      font-size:15px;
      color:#1c1c1a;
    }

    #slot-selection-empty,
    #special-selection-empty{
      background:#fff;
      border:1px dashed #d0d0d0;
      border-radius:8px;
      padding:14px;
      font-size:14px;
      color:#555;
    }

    .slot-summary{
      font-size:14px;
      line-height:1.5;
      color:#222;
    }

    .slot-summary .label{
      font-weight:700;
    }

    .emission-card{
      background:var(--postit);
      color:#fff;
      border:1px solid var(--postit-border);
      padding:8px 10px;
      border-radius:6px;
      font-size:12px;
      font-weight:700;
      cursor:pointer;
      user-select:none;
      margin-bottom:8px;
    }

    .emission-card small{
      display:block;
      margin-top:4px;
      font-weight:400;
      opacity:.95;
    }

    .custom-tooltip{
      position:fixed;
      display:none;
      background:rgba(0,0,0,.85);
      color:#fff;
      padding:4px 8px;
      border-radius:4px;
      font-size:12px;
      pointer-events:none;
      z-index:9999;
    }

    .slot-actions{
      margin-top:12px;
    }

    .btn-remove-assignment{
      width:100%;
      border:1px solid #b9475a;
      background:#fff;
      color:#b9475a;
      border-radius:6px;
      padding:8px 10px;
      font-size:13px;
      font-weight:700;
      cursor:pointer;
    }

    .btn-remove-assignment:hover{
      background:#fff5f6;
    }

    .special-placeholder{
      font-size:14px;
      line-height:1.5;
      color:#333;
    }

    .special-placeholder p{
      margin:0 0 10px;
    }

    .emission-card.is-auto-generated {
  border: 2px solid #000;
}

.emission-card.is-auto-generated small {
  font-weight: 700;
}

    @media (max-width: 900px){
      .grid-area{
        overflow-x:auto;
      }
    }
  </style>
{% endblock %}
{% block body %}
  <h1>
    Grille de programmation
  </h1>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
    <a href="{{ path('admin.grille.index', {'startOfWeek': startOfWeek|date_modify('-7 days')|date('Y-m-d')}) }}">
      ⬅ Semaine précédente
    </a>
    <h2 style="font-size:18px;margin:0;">
      <a href="{{ path('admin.grille.index_current') }}">
        📅 Semaine actuelle
      </a>
      Semaine du
      {{ startOfWeek|date('d/m/Y') }}
    </h2>
    <a href="{{ path('admin.grille.index', {'startOfWeek': startOfWeek|date_modify('+7 days')|date('Y-m-d')}) }}">
      Semaine suivante ➡
    </a>
  </div>
  <div class="schedule-layout" data-controller="grid">
    <div class="grid-area">
      <div class="schedule-grid">
        <div class="head hour" style="grid-column:1;grid-row:1;">
          Heure
        </div>
        {% for i in 0..6 %}
          {% set jour = startOfWeek|date_modify("+" ~ i ~ " days") %}
          <div class="head" style="grid-column: {{ 2 + i }}; grid-row:1;">
            {{ jour|format_date('medium', locale='fr') }}
          </div>
        {% endfor %}
        <div class="hours-col">
          {% for i in 0..95 %}
            <div class="h-slot {{ i % 4 == 0 ? 'hour-start' : '' }}" style="top: calc({{ i }} * var(--slot-h));"></div>
          {% endfor %}
          {% for h in 0..23 %}
            <div class="hour-label" style="top: calc({{ h * 4 }} * var(--slot-h));">
              {{ "%02d:00"|format(h) }}
            </div>
          {% endfor %}
        </div>
        {% for dayIndex in 0..6 %}
          <div class="day-col" data-grid-target="day" style="grid-column: {{ 2 + dayIndex }};">
            {% for i in 0..95 %}
              <div class="day-slot {{ i % 4 == 0 ? 'hour-start' : '' }}" style="top: calc({{ i }} * var(--slot-h));"></div>
            {% endfor %}
            {% for seg in (daySegments[dayIndex] ?? []) %}
              {% set slots = (seg.duration / 15)|round(0, 'ceil') %}
              {% set displayTitle = seg.displayTitle|default(seg.title|default('Créneau')) %}
              {% set categoryTitle = seg.categoryTitle|default(seg.title|default('Catégorie inconnue')) %}
              {% set ruleNumber = seg.ruleNumber|default(null) %}
              {% set ruleDisplayName = seg.ruleDisplayName|default(categoryTitle) %}
              {% set broadcastRank = seg.broadcastRank|default(1) %}
              {% set isRebroadcast = broadcastRank > 1 %}
              {% set rebroadcastLabel = broadcastRank == 2 ? 'R1 auto' : (broadcastRank == 3 ? 'R2 auto' : 'Rediff. auto') %}
              {% set postitClasses = [
                'postit',
                seg.assigned|default(false) ? 'assigned',
                isRebroadcast ? 'postit--rebroadcast' : 'postit--first-broadcast'
              ]|filter(v => v) %}
              <div class="{{ postitClasses|join(' ') }}" style="top: calc({{ seg.startIndex }} * var(--slot-h)); height: calc({{ slots }} * var(--slot-h));" data-slots="{{ slots }}" data-duration="{{ seg.duration }}" data-rule-id="{{ seg.ruleId|default('') }}" data-rule-number="{{ ruleNumber ?? '' }}" data-rule-display-name="{{ ruleDisplayName }}" data-slot-id="{{ seg.slotId|default('') }}" data-broadcast-rank="{{ broadcastRank }}" data-starts-at="{{ seg.startsAt|default('') }}" data-category-title="{{ categoryTitle }}" data-assigned-emission-id="{{ seg.emissionId|default('') }}" data-assigned-emission-title="{{ seg.emissionTitle|default('') }}" data-slot-locked="{{ isRebroadcast ? 'true' : 'false' }}" {% if not isRebroadcast %} data-action="click->grid#selectSlot" {% endif %} title="{% if isRebroadcast %}{{ ruleDisplayName }} — rediffusion générée automatiquement depuis la première diffusion{% else %}{{ ruleDisplayName }} • {{ seg.duration }} min{% endif %}" draggable="{{ isRebroadcast ? 'false' : 'true' }}" {% if isRebroadcast %} aria-disabled="true" {% endif %}>
                <div class="postit__content">
                  <span class="postit__label">
                    🎙
                    {{ displayTitle }}
                    •
                    {{ seg.duration }}
                    min
                  </span>
                  {% if ruleNumber %}
                    <span class="postit__badge">
                      R
                      {{ ruleNumber }}
                      {% if isRebroadcast %}
                        ·
                        {{ rebroadcastLabel }}
                      {% endif %}
                    </span>
                  {% elseif isRebroadcast %}
                    <span class="postit__badge">
                      {{ rebroadcastLabel }}
                    </span>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
    <aside class="sidebar">
      <h2>
        Programmation
      </h2>
      <div class="sidebar-mode-switch">
        <button type="button" class="mode-btn is-active" data-grid-target="modeRegularBtn" data-action="click->grid#showRegularMode">
          Régulières
        </button>
        <button type="button" class="mode-btn" data-grid-target="modeSpecialBtn" data-action="click->grid#showSpecialMode">
          Non régulières
        </button>
      </div>
      <div data-grid-target="regularPanel">
        <h2>
          Émissions disponibles
        </h2>
        <div id="slot-selection-empty" data-grid-target="emptyState">
          Sélectionne un créneau dans la grille pour afficher les émissions compatibles.
        </div>
        <div id="slot-selection-panel" data-grid-target="sidebarPanel" style="display:none;">
          <div class="sidebar-section">
            <h3>
              Créneau sélectionné
            </h3>
            <div class="slot-summary" data-grid-target="slotSummary"></div>
            <div class="slot-actions" data-grid-target="slotActions" style="display:none;">
              <button type="button" class="btn-remove-assignment" data-action="click->grid#removeAssignment">
                Retirer l’émission
              </button>
            </div>
          </div>
          <div class="sidebar-section">
            <h3>
              Émissions suggérées
            </h3>
            <div id="emissions-pool" data-grid-target="emissionsList"></div>
          </div>
        </div>
      </div>
      <div data-grid-target="specialPanel" style="display:none;">
        <h2>
          Émissions non régulières
        </h2>
        <div id="special-selection-empty" data-grid-target="specialEmptyState">
          Passe en mode « non régulières », puis clique un créneau de la grille pour préparer une programmation ponctuelle.
        </div>
        <div data-grid-target="specialSidebarPanel" style="display:none;">
          <div class="sidebar-section">
            <h3>
              Créneau sélectionné
            </h3>
            <div class="slot-summary" data-grid-target="specialSlotSummary"></div>
          </div>
          <div class="sidebar-section">
            <div class="special-placeholder">
              <p>
                <strong>
                  Programmation ponctuelle
                </strong>
              </p>
              <p>
                Cette zone servira à programmer une émission non régulière, sans règle de programmation.
              </p>
              <p>
                Tu pourras ensuite y brancher la recherche d’émissions et l’action d’affectation dédiée.
              </p>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
  <div id="tooltip" class="custom-tooltip"></div>
{% endblock %}
