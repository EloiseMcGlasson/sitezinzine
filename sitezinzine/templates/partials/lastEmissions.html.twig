<style>
/* =========================
   SECTION : ÉMISSIONS RÉCENTES
   ========================= */

.bodylast{
  display: flex;
  flex-direction: column;
  margin: 0;
  padding: 0;
  font-family: "Montserrat Alternates", sans-serif;
  font-weight: 700;
  background: linear-gradient(#E4013A, #B81C61);
}

.bodylast a{
  text-decoration: none;
}

.bodylast .bottom{
  display: block;
  width: 100%;
  margin-bottom: -1px;
}


/* =========================
   EN-TÊTE
   ========================= */

.bodylast .titrelast{
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  padding: 20px 16px 10px;
}

.bodylast .titrelast img{
  display: block;
  width: 120px;
  height: auto;
}

.bodylast h1,
.bodylast h3{
  margin: 0;
  color: #fff;
  text-align: left;
}

.bodylast h1{
  font-size: clamp(24px, 3.2vw, 36px);
  font-weight: 900;
  line-height: 1.05;
}

.bodylast h3{
  margin-top: 6px;
  font-size: clamp(14px, 2vw, 24px);
  font-weight: 700;
  line-height: 1.1;
}


/* =========================
   GRILLE DES CARTES
   ========================= */

/* Desktop large */
@media screen and (min-width: 1401px){
  .bodylast article{
    display: grid;
    grid-template-columns: repeat(3, 350px);
    justify-content: center;
    gap: 60px 100px;
    padding: 20px 20px 50px;
    margin: 0 auto;
  }

  .bodylast .carte{
    width: 350px;
    height: 300px;
  }
}

/* Petit desktop / laptop */
@media screen and (min-width: 1024px) and (max-width: 1400px){
  .bodylast article{
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 350px));
    justify-content: center;
    gap: 28px 40px;
    padding: 18px 16px 44px;
    margin: 0 auto;
  }

  .bodylast .carte{
    width: 350px;
    height: 300px;
  }

  .bodylast .titrelast{
    gap: 14px;
    padding: 18px 14px 10px;
  }

  .bodylast .titrelast img{
    width: 100px;
  }
}

/* Tablette / mobile */
@media screen and (max-width: 1023px){
  .bodylast article{
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    justify-content: center;
    gap: 26px;
    padding: 16px 14px 40px;
  }

  .bodylast .carte{
    width: 100%;
    max-width: 350px;
    height: 300px;
    margin: 0 auto;
  }

  .bodylast .titrelast{
    justify-content: flex-start;
    max-width: 720px;
    margin: 0 auto;
  }
}


/* =========================
   CARTE
   ========================= */

.bodylast .carte{
  position: relative;
  overflow: hidden;
  border-radius: 12px;
  background-color: #000;
  background-position: center;
  background-repeat: no-repeat;
  background-size: cover;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.45);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.bodylast .carte:hover{
  transform: translateY(-4px);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
}


/* =========================
   BANDEAU THÈME EN HAUT
   ========================= */

.bodylast .theme{
  margin: 0;
  padding: 10px 12px;
  font-family: "Source Code Pro", monospace;
  font-size: 15px;
  text-align: center;
  color: #fff;
  background-color: #7E4095;
  -webkit-text-stroke-width: 0.5px;
  -webkit-text-stroke-color: black;
}


/* =========================
   VOILE BAS DE CARTE
   ========================= */

.bodylast .transparent{
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: calc(100% - 110px);
  background: rgba(163, 163, 142, 0.55);
  z-index: 1;
  pointer-events: none;
}


/* =========================
   CONTENU BAS DE CARTE
   ========================= */

.bodylast .content{
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  padding: 0 12px 12px;
}

.bodylast .categorie{
  position: absolute;
  top: -20px;
  left: 22px;
  right: 22px;
  z-index: 3;

  display: flex;
  align-items: center;
  justify-content: center;

  min-height: 56px;
  padding: 6px 12px;
  border-radius: 8px;
  box-sizing: border-box;

  background-color: #35BAC0;
  color: white;
  text-align: center;
  font-family: "Source Code Pro", monospace;
  font-size: 16px;
  font-weight: 600;
  line-height: 1.2;
}

.bodylast .categorie p{
  margin: 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* Réserve la place du cartouche dans le bloc texte */
.bodylast .infos{
  padding-top: 48px;
}

.bodylast .titre{
  margin: 0 18px 6px;
  padding: 0;
  overflow: hidden;
  font-family: "Montserrat", sans-serif;
  font-size: 22px;
  font-weight: 600;
  line-height: 1.15;
  color: #fff;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  min-height: calc(2 * 1.15em);
}

.bodylast .date{
  margin: 0 18px 0;
  font-size: 18px;
  font-weight: 400;
  color: #fff;
}


/* =========================
   BOUTON ÉCOUTE
   ========================= */

.bodylast .ecoute{
  position: absolute;
  right: 10px;
  bottom: 10px;
  z-index: 5;
}

.bodylast .ecoute a{
  position: relative;
  z-index: 6;
}

.bodylast .ecoute img{
  display: block;
  width: 40px;
  height: 40px;
}


/* =========================
   RESET DES <p> INTERNES
   ========================= */

.bodylast .theme p,
.bodylast .categorie p,
.bodylast .titre p,
.bodylast .date p{
  margin: 0;
}


/* =========================
   AJUSTEMENTS MOBILE
   ========================= */

@media (max-width: 480px){
  .bodylast .titrelast img{
    width: 55px;
    height: 55px;
  }

  .bodylast .titre{
    font-size: 20px;
  }

  .bodylast .date{
    font-size: 16px;
  }

  .bodylast .categorie{
    font-size: 14px;
  }
}


/* =========================
   MOBILE EN PAYSAGE
   ========================= */

@media (max-width: 900px) and (orientation: landscape){
  .bodylast .titrelast{
    gap: 12px;
    padding: 12px 12px 6px;
  }

  .bodylast .titrelast img{
    width: 80px;
  }

  .bodylast article{
    gap: 18px;
    padding: 12px 10px 24px;
  }

  .bodylast .carte{
    height: 240px;
  }

  .bodylast .titre{
    font-size: 20px;
  }

  .bodylast .date{
    font-size: 16px;
  }
}
</style>
<div class="bodylast">
        <div class="titrelast">
            <img src="/images/illu-radio-libre.gif" alt="">
                <div>
                    <h1>
                        ÉMISSIONS RÉCENTES
                    </h1>
                    <h3>
                        À réécouter
                    </h3>
                </div>
            </div>
            <article>
                {% for lastEmissionByGroupTheme in lastEmissionsByTheme %}
                    {% if lastEmissionByGroupTheme.theme_thumbnail is not empty %}
                        {% set bgImage = asset('/uploads/images/theme/' ~ lastEmissionByGroupTheme.theme_thumbnail|url_encode) %}
                    {% else %}
                        {% set bgImage = asset('/uploads/images/emissions/emission-zinzine.jpg') %}
                    {% endif %}
                    <div class="carte" style="background-image:url('{{ bgImage }}');">
                        <div class="theme">
                            <p>
                                {{ lastEmissionByGroupTheme.theme_group|default('')|upper }}
                            </p>
                        </div>
                    <div class="transparent"></div>
                        {# lien vers la page émission (zone texte + voile) #}
                        <a href="{{ path('emission.show', {id: lastEmissionByGroupTheme.emission_id}) }}" aria-label="Voir l'émission">
                        <div class="content">
                                <div class="content">
    <div class="categorie">
        <p>
            {{ lastEmissionByGroupTheme.categorie_titre|upper }}
        </p>
    </div>

    <div class="infos">
        <div class="titre">
            <p>
                {{ lastEmissionByGroupTheme.emission_titre }}
            </p>
        </div>
        <div class="date">
            <p>
                Le
                {{ lastEmissionByGroupTheme.last_diffusion|format_datetime('medium','short', locale='fr') }}
            </p>
        </div>
    </div>
</div>
                            </div>
                        </a>
                        {# bouton écoute séparé (reste cliquable) #}
                        <div class="ecoute">
                            <a href="{{ lastEmissionByGroupTheme.emission_url }}" target="_blank" rel="noopener" aria-label="Écouter l'émission">
                                <img src="/images/lecteur.png" alt="Écoutez l'émission"></a>
                            </div>
                        </div>
                    {% endfor %}
                </article>
                <img class="bottom" src="/images/top-content-dechire-D.gif" alt=""></div>
                